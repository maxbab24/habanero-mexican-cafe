  { name: "Beef Fajitas", price: "$19.95", desc: "Tender strips of skirt steak over grilled onions, bell peppers, tomatoes" },
  { name: "Beef Fajita Ranchera 🌶️🌶️", price: "$19.95", desc: "Same as fajitas but with jalapeños, tomatoes, onions — very spicy" },
  { name: "Carne Asada", price: "$19.95", desc: "Skirt steak served with jalapeños and onions" },
  { name: "Chicken Fajitas", price: "$18.95", desc: "Grilled chicken breast strips with grilled onions, bell peppers, tomatoes" },
  { name: "Chicken Fajita Ranchera 🌶️🌶️", price: "$18.95", desc: "Grilled chicken breast strips with jalapeños, tomatoes, onions — very spicy" },
  { name: "Steak Ranchero 🌶️🌶️", price: "$19.95", desc: "Skirt steak with grilled jalapeños, tomatoes, onion — very spicy" },
  { name: "Chuleta Ranchera 🌶️", price: "$19.95", desc: "Pork chop ranchero style" },
  { name: "Tripas Plate", price: "$18.95", desc: "Grilled beef tripe" },
