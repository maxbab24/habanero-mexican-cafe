  { name: "Shrimp Ranchero", price: "$18.95", desc: "Grilled and blackened shrimp mixed with jalapeños, tomatoes, and onions" },
  { name: "Taco Plate", price: "$14.95", desc: "2 Tacos filled with your choice of filling (Fajita, Asado, Shrimp, Fish +$1.00)" },
  { name: "Barbacoa Plate", price: "$15.95", desc: "Mexican style shredded beef" },
  { name: "Burrito Plate", price: "$14.95", desc: "2 Mini burritos with your choice of filling, topped with white cheese (Fajita, Asado, Shrimp, Fish +$1.00)" },
  { name: "Carne Guisada Plate", price: "$15.95", desc: "Tender beef chunks in a special gravy" },
