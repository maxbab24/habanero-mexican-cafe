  { name: "Picadillo Plate", price: "$13.95", desc: "2 Crispy corn tortillas filled with ground beef or chicken, served with guac and sour cream" },
  { name: "Catfish Ranchero", price: "$18.95", desc: "Grilled and blackened fillet topped with grilled onions, jalapeños, and tomatoes" },
