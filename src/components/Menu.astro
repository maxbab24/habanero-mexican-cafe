  { name: "*El Patron", price: "$13.95", desc: "2 fried eggs served with salsa" },
  { name: "*Deluxe Ranchero", price: "$13.95", desc: "3 over easy eggs topped with queso ranchero" },
  { name: "*Huevos Gringos", price: "$13.95", desc: "2 over easy eggs topped with queso ranchero" },
  { name: "Chori Midas", price: "$13.95", desc: "Chorizo with crispy tortilla, egg, cheese, jalapeños, tomato, onion" },
  { name: "Machacado Plate", price: "$13.95", desc: "Shredded dried beef, egg, jalapeño, tomato, onion" },
  { name: "Midas Plate", price: "$11.50", desc: "Crispy tortilla filled with egg, cheese, jalapeños, tomato, onion" },
  { name: "Huevos con Tocino", price: "$10.50", desc: "2 eggs scrambled with bacon" },
  { name: "Huevos con Chorizo", price: "$10.50", desc: "2 eggs scrambled with chorizo" },
  { name: "Huevos Ala Mexicana", price: "$9.25", desc: "2 eggs scrambled Mexican style" },
