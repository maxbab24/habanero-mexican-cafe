---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background food photo -->
  <div class="absolute inset-0">
    <img src="/images/food-tray.webp" alt="Habanero Mexican Cafe food spread" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-stone-900/70"></div>
  </div>

  <div class="relative z-10 text-center px-4 sm:px-6 max-w-3xl mx-auto">
    <img src="/images/logo.webp" alt="Habanero Mexican Cafe" class="h-32 sm:h-40 w-auto mx-auto mb-8 drop-shadow-2xl" />

    <p class="text-orange-300 text-sm font-bold uppercase tracking-widest mb-4">
      Austin, Texas · Est. 1997 · Family Owned
    </p>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-5 leading-tight">
      A Taste of Home,<br />
      <span class="italic font-normal text-orange-300">Right Here in Austin</span>
    </h1>
    <p class="text-stone-300 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
      27 years of recipes passed down through the Ibarra family. Come hungry, leave happy.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#menu" class="bg-red-700 hover:bg-red-800 text-white font-bold px-8 py-4 rounded-full transition-all hover:scale-105 shadow-lg">
        View Our Menu
      </a>
      <a href="#specials" class="bg-orange-500 hover:bg-orange-600 text-stone-900 font-bold px-8 py-4 rounded-full transition-all hover:scale-105 shadow-lg">
        Today's Specials
      </a>
    </div>

    <div class="mt-14 flex flex-wrap justify-center gap-8 text-center">
      <div>
        <p class="text-orange-400 font-bold text-2xl">27+ Years</p>
        <p class="text-stone-400 text-sm">Serving Austin</p>
      </div>
      <div class="text-stone-600">·</div>
      <div>
        <p class="text-orange-400 font-bold text-2xl">7am – 3pm</p>
        <p class="text-stone-400 text-sm">Open Every Day</p>
      </div>
      <div class="text-stone-600">·</div>
      <div>
        <p class="text-orange-400 font-bold text-2xl">Catering</p>
        <p class="text-stone-400 text-sm">Available</p>
      </div>
    </div>
  </div>
</section>
