  { name: "Combo #1", desc: "1 enchilada, 1 crispy beef taco, 1 bean tostada" },
  { name: "Combo #2", desc: "3 enchiladas, 2 crispy beef tacos" },
  { name: "Combo #3", desc: "1 flauta, 1 crispy beef taco, 1 bean tostada" },
  { name: "Combo #4", desc: "1 enchilada, 2 crispy beef tacos" },
];

const texmex = [
  { name: "Nikki Wiki", price: "$6.95", desc: "1 crispy beef taco, side of rice, side of queso" },
  { name: "Zach Attack", price: "$15.25", desc: "2 tacos filled with your choice of meat, topped with queso, side of rice, beans, pico" },
  { name: "Habanero Burrito", price: "$15.25", desc: "Large flour tortilla with your choice of meat, covered with salsa ranchera, topped with queso" },
  { name: "El Gringo Burrito", price: "$15.25", desc: "Large flour tortilla with your choice of meat, covered in queso. Fajita, Asado, Shrimp, Fish +$1.00" },
];

const botanas = [
  { name: "Nachos Regular", price: "$8.25", desc: "Refried beans & cheese" },
  { name: "Chips and Salsa", price: "$5.25" },
  { name: "Nachos Supreme", price: "$10.55" },
  { name: "Chile Con Queso", price: "$5.55" },
  { name: "Nachos Habanero", price: "$12.95", desc: "Chicken fajita nachos covered in chile con queso" },
  { name: "Quesadillas Habanero", price: "$12.95", desc: "Beef or chicken quesadilla covered in our chile con queso sauce" },
];

