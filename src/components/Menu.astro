  { name: "Supremas Enchiladas", desc: "2 chicken covered in our salsa roja and white cheese" },
  { name: "Regular Enchiladas", desc: "2 beef, chicken or cheese, covered in salsa roja and cheddar cheese" },
  { name: "Verde Enchiladas", desc: "2 beef, chicken or cheese, covered in salsa verde and cheese" },
