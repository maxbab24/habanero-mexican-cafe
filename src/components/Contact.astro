---
---
<section id="contact" class="py-24 bg-stone-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-orange-400 text-sm font-bold uppercase tracking-widest mb-3">Get In Touch</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-stone-100 mb-4">We'd Love to Hear From You</h2>
      <p class="text-stone-400 text-lg max-w-xl mx-auto">
        Questions about catering, hours, or our menu? Reach out — we'll get back to you within 48–72 hours.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Info -->
      <div class="space-y-7">
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 bg-stone-700 rounded-2xl flex items-center justify-center text-xl flex-shrink-0">📍</div>
          <div>
            <h3 class="font-bold text-stone-100 mb-1">Address</h3>
            <p class="text-stone-400">501 W. Oltorf St<br />Austin, TX 78704</p>
            <a href="https://maps.google.com/?q=501+W+Oltorf+St+Austin+TX+78704" target="_blank" rel="noopener noreferrer" class="text-orange-400 hover:text-orange-300 text-sm font-bold transition-colors">Get Directions →</a>
          </div>
        </div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 bg-stone-700 rounded-2xl flex items-center justify-center text-xl flex-shrink-0">📞</div>
          <div>
            <h3 class="font-bold text-stone-100 mb-1">Phone</h3>
            <a href="tel:5124160443" class="text-orange-400 hover:text-orange-300 text-lg font-bold transition-colors">(512) 416-0443</a>
          </div>
        </div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 bg-stone-700 rounded-2xl flex items-center justify-center text-xl flex-shrink-0">✉️</div>
          <div>
            <h3 class="font-bold text-stone-100 mb-1">Email</h3>
            <a href="mailto:habaneromexicancafe@gmail.com" class="text-orange-400 hover:text-orange-300 transition-colors break-all font-bold">habaneromexicancafe@gmail.com</a>
          </div>
        </div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 bg-stone-700 rounded-2xl flex items-center justify-center text-xl flex-shrink-0">📘</div>
          <div>
            <h3 class="font-bold text-stone-100 mb-1">Facebook</h3>
            <a href="https://www.facebook.com/108076339180" target="_blank" rel="noopener noreferrer" class="text-orange-400 hover:text-orange-300 font-bold transition-colors">Habanero Mexican Cafe</a>
            <p class="text-stone-500 text-sm">3,430 followers</p>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-stone-700 rounded-3xl p-8 shadow-md border border-stone-600">
        <form class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-bold text-stone-300 mb-1.5">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" class="w-full px-4 py-3 rounded-xl border border-stone-600 focus:border-orange-500 focus:ring-2 focus:ring-orange-900 outline-none transition bg-stone-800 text-stone-100 placeholder:text-stone-500" />
          </div>
          <div>
            <label for="email" class="block text-sm font-bold text-stone-300 mb-1.5">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" class="w-full px-4 py-3 rounded-xl border border-stone-600 focus:border-orange-500 focus:ring-2 focus:ring-orange-900 outline-none transition bg-stone-800 text-stone-100 placeholder:text-stone-500" />
          </div>
          <div>
            <label for="subject" class="block text-sm font-bold text-stone-300 mb-1.5">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="e.g. Catering inquiry" class="w-full px-4 py-3 rounded-xl border border-stone-600 focus:border-orange-500 focus:ring-2 focus:ring-orange-900 outline-none transition bg-stone-800 text-stone-100 placeholder:text-stone-500" />
          </div>
          <div>
            <label for="message" class="block text-sm font-bold text-stone-300 mb-1.5">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us how we can help..." class="w-full px-4 py-3 rounded-xl border border-stone-600 focus:border-orange-500 focus:ring-2 focus:ring-orange-900 outline-none transition bg-stone-800 text-stone-100 placeholder:text-stone-500 resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-red-700 hover:bg-red-600 text-white font-bold py-3.5 rounded-xl transition-colors shadow-sm">
            Send Message
          </button>
          <p class="text-stone-500 text-xs text-center">We respond within 48–72 hours.</p>
        </form>
      </div>
    </div>
  </div>
</section>
