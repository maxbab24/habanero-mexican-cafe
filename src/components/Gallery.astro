---
---
<section class="py-20 bg-stone-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-orange-400 text-sm font-bold uppercase tracking-widest mb-3">From Our Kitchen</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-stone-100">Fresh. Authentic. Delicious.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group md:col-span-2 h-72 md:h-96">
        <img
          src="/images/fajitas-table.webp"
          alt="Sizzling fajitas and plates at Habanero Mexican Cafe Austin TX"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group h-72 md:h-96">
        <img
          src="/images/breakfast-tacos.webp"
          alt="Habanero breakfast tacos Austin TX"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow group h-72 md:col-span-3">
        <img
          src="/images/food-tray.webp"
          alt="Habanero full meal spread — tacos, burritos, fajitas, rice and more"
          loading="lazy"
          class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    </div>
  </div>
</section>
