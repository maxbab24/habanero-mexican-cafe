  { name: "Barbacoa", price: "$16.00" },
  { name: "Carnitas", price: "$16.00" },
  { name: "Carne Guisada", price: "$16.00" },
  { name: "Chicken Fajita", price: "$20.00" },
  { name: "Tripas", price: "$23.00" },
  { name: "Picadillo", price: "$14.00" },
  { name: "Beef Fajita", price: "$23.00" },
];
---

<section id="menu" class="py-24 bg-stone-900 text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-orange-400 text-sm font-bold uppercase tracking-widest mb-3">Full Menu</p>
      <h2 class="text-4xl sm:text-5xl font-bold mb-4">Something for Everyone</h2>
      <p class="text-stone-400 text-lg">Dine-in · Take-out · Catering</p>
    </div>

    <!-- Tacos / Gorditas / Tortas -->
    <div class="mb-16">
      <div class="flex flex-wrap gap-4 mb-8">
        {sections[0].categories.map((cat) => (
          <div class="bg-red-700 rounded-2xl px-6 py-4 flex-1 min-w-[160px] text-center">
            <p class="font-bold text-lg">{cat.name}</p>
            <p class="text-red-200 text-sm">{cat.note}</p>
            <p class="text-2xl font-bold mt-1 text-orange-300">{cat.price}</p>
          </div>
        ))}
      </div>
      <h3 class="text-orange-400 text-xs font-bold uppercase tracking-widest mb-4">Choose Your Meat</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
        {sections[0].meats.map((meat) => (
          <div class="bg-stone-800 rounded-xl px-4 py-3 flex items-start justify-between gap-2">
            <div>
              <p class="font-bold text-stone-100 text-sm">{meat.name}</p>
              {meat.note && <p class="text-stone-400 text-xs mt-0.5">{meat.note}</p>}
            </div>
            {meat.extra && <span class="text-orange-400 text-xs font-bold whitespace-nowrap">{meat.extra}</span>}
          </div>
        ))}
      </div>
      <div class="bg-stone-800 rounded-2xl p-5">
        <p class="text-orange-400 text-xs font-bold uppercase tracking-widest mb-3">Add-Ons</p>
        <div class="flex flex-wrap gap-3">
          {sections[0].addons.map((a) => (
            <span class="bg-stone-600 text-stone-300 text-sm px-3 py-1.5 rounded-full">
              {a.name} <span class="text-orange-400 font-bold">{a.price}</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Botanas -->
    <div class="mb-16">
      <h3 class="text-2xl font-bold mb-1">Botanas</h3>
      <p class="text-stone-400 text-sm mb-6">Appetizers &amp; Starters</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {botanas.map((item) => (
          <div class="bg-stone-800 rounded-xl p-4 flex justify-between gap-3">
            <div>
              <p class="font-bold text-stone-100">{item.name}</p>
              {item.desc && <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>}
            </div>
            <span class="text-orange-400 font-bold whitespace-nowrap">{item.price}</span>
          </div>
        ))}
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Platos de Casa -->
    <div class="mb-16">
      <h3 class="text-2xl font-bold mb-1">Platos de Casa</h3>
      <p class="text-stone-400 text-sm mb-6">All plates served with rice, beans &amp; pico</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {platos.map((item) => (
          <div class="bg-stone-800 rounded-xl p-4 flex justify-between gap-3">
            <div>
              <p class="font-bold text-stone-100">{item.name}</p>
              <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
            </div>
            <span class="text-orange-400 font-bold whitespace-nowrap">{item.price}</span>
          </div>
        ))}
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Specialties -->
    <div class="mb-16">
      <h3 class="text-2xl font-bold mb-1">Specialties</h3>
      <p class="text-stone-400 text-sm mb-6">All plates served with rice, charro beans &amp; pico</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {specialties.map((item) => (
          <div class="bg-stone-800 rounded-xl p-4 flex justify-between gap-3">
            <div>
              <p class="font-bold text-stone-100">{item.name}</p>
              <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
            </div>
            <span class="text-orange-400 font-bold whitespace-nowrap">{item.price}</span>
          </div>
        ))}
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Enchiladas + Combos + Tex Mex -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
      <div>
        <h3 class="text-2xl font-bold mb-1">Enchiladas</h3>
        <p class="text-stone-400 text-sm mb-6">Includes rice, beans &amp; pico · <span class="text-orange-400 font-bold">$12.95</span></p>
        <div class="space-y-3">
          {enchiladas.map((item) => (
            <div class="bg-stone-800 rounded-xl p-4">
              <p class="font-bold text-stone-100">{item.name}</p>
              <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-2xl font-bold mb-1">Combos</h3>
        <p class="text-stone-400 text-sm mb-6">Includes rice &amp; beans · <span class="text-orange-400 font-bold">$14.25</span></p>
        <div class="space-y-3">
          {combos.map((item) => (
            <div class="bg-stone-800 rounded-xl p-4">
              <p class="font-bold text-stone-100">{item.name}</p>
              <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>

        <h3 class="text-2xl font-bold mt-10 mb-6">Tex Mex Specialties</h3>
        <div class="space-y-3">
          {texmex.map((item) => (
            <div class="bg-stone-800 rounded-xl p-4 flex justify-between gap-3">
              <div>
                <p class="font-bold text-stone-100">{item.name}</p>
                <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
              </div>
              <span class="text-orange-400 font-bold whitespace-nowrap">{item.price}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Breakfast -->
    <div class="mb-16">
      <h3 class="text-2xl font-bold mb-1">Breakfast</h3>
      <p class="text-stone-400 text-sm mb-6">All plates include beans, potato &amp; tortillas · *served with salsa</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {breakfast.map((item) => (
          <div class="bg-stone-800 rounded-xl p-4 flex justify-between gap-3">
            <div>
              <p class="font-bold text-stone-100">{item.name}</p>
              <p class="text-stone-400 text-sm mt-0.5">{item.desc}</p>
            </div>
            <span class="text-orange-400 font-bold whitespace-nowrap">{item.price}</span>
          </div>
        ))}
      </div>
      <div class="mt-6 bg-stone-800 rounded-2xl p-5">
        <p class="text-orange-400 text-xs font-bold uppercase tracking-widest mb-3">Breakfast à la carte</p>
        <div class="flex flex-wrap gap-3 text-sm text-stone-300">
          {["Potato & Egg", "Bacon & Egg", "Chorizo & Egg", "Sausage & Egg", "Bean & Egg"].map((item) => (
            <span>{item} <span class="text-orange-400 font-bold">$3.00</span></span>
          ))}
          <span>Migas <span class="text-orange-400 font-bold">$4.00</span></span>
          <span>Machacado <span class="text-orange-400 font-bold">$4.50</span></span>
        </div>
      </div>
    </div>

    <hr class="border-stone-700 mb-16" />

    <!-- Libres de Carne -->
    <div>
      <h3 class="text-2xl font-bold mb-1">Libres de Carne</h3>
      <p class="text-stone-400 text-sm mb-2">Meat to-go — perfect for take-out</p>
      <p class="text-stone-500 text-xs mb-6">Add a Special for +$3.00: includes 1 dozen tortillas, 8oz salsa, 8oz pico</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mb-8">
        {toGo.map((item) => (
          <div class="bg-stone-800 rounded-xl p-4 text-center">
            <p class="font-bold text-stone-100 text-sm">{item.name}</p>
            <p class="text-orange-400 font-bold text-lg mt-1">{item.price}</p>
          </div>
        ))}
      </div>
      <div class="bg-stone-800 rounded-2xl p-6">
        <p class="text-orange-400 text-xs font-bold uppercase tracking-widest mb-4">Sides &amp; Extras (To-Go)</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-3 gap-x-6 text-sm">
          <div class="flex justify-between"><span class="text-stone-300">Beans (8/16/32oz)</span><span class="text-orange-400 font-bold">$3/$6/$12</span></div>
          <div class="flex justify-between"><span class="text-stone-300">Rice (8/16/32oz)</span><span class="text-orange-400 font-bold">$3/$6/$12</span></div>
          <div class="flex justify-between"><span class="text-stone-300">Salsa (8/16/32oz)</span><span class="text-orange-400 font-bold">$3/$6/$12</span></div>
          <div class="flex justify-between"><span class="text-stone-300">Salsa Ranchera (8/16/32oz)</span><span class="text-orange-400 font-bold">$4/$8/$16</span></div>
          <div class="flex justify-between"><span class="text-stone-300">Queso w/ chips (8/16/32oz)</span><span class="text-orange-400 font-bold">$5.25/$10.50/$21</span></div>
          <div class="flex justify-between"><span class="text-stone-300">Guacamole (8/16/32oz)</span><span class="text-orange-400 font-bold">$4.75/$9.50/$19</span></div>
        </div>
      </div>
    </div>

  </div>
</section>
